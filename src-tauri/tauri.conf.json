{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoltMD",
  "version": "0.1.0",
  "identifier": "com.madhouse.boltmd",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BoltMD",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd", "mkdn"],
        "mimeType": "text/markdown",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlGRkNCRTEzNUY2QzBBRDYKUldUV0NteGZFNzc4bjZCUnpXcXJVQ2RZVkdwd1prblZydWtuZmdhY3c3cDVLajdSQ3EyQm5PMkYK",
      "endpoints": [
        "https://github.com/bolthq/boltmd/releases/latest/download/latest.json"
      ]
    }
  }
}
